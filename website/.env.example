# ─────────────────────────────────────────────────────────────────────────────
# QEncode website environment variables
# Copy this file to .env.local for local development.
# Add all values to Vercel → Project Settings → Environment Variables for prod.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Lemon Squeezy ─────────────────────────────────────────────────────────────
# Public checkout URLs (already hardcoded as fallbacks in lib/payments.js)
NEXT_PUBLIC_LS_FULL_SUITE_CHECKOUT_URL=https://quantumalgorithmbenchmarking.lemonsqueezy.com/checkout/buy/9bfda82b-15b1-43af-ba2d-70f5a381705d
NEXT_PUBLIC_LS_SINGLE_MOLECULE_CHECKOUT_URL=https://quantumalgorithmbenchmarking.lemonsqueezy.com/checkout/buy/86b8c0a4-ed45-45dd-9fd5-520f097296ec

# Webhook signing secret — from LS Dashboard → Settings → Webhooks → [your webhook] → Signing Secret
# Used to verify that POST requests to /api/webhooks/lemonsqueezy are genuine.
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_signing_secret_here

# ── Resend (transactional email) ──────────────────────────────────────────────
# Get your API key at https://resend.com/api-keys
# Free tier: 3,000 emails/month, 100/day
# IMPORTANT: You must verify the domain qencode-benchmark.org in Resend before
#            emails send from noreply@qencode-benchmark.org. Add the DNS records
#            Resend gives you to your domain registrar.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Admin email to receive new order notifications (triggers execution queue)
# Defaults to support@qencode-benchmark.org if not set
ADMIN_EMAIL=support@qencode-benchmark.org

# ── Neon Postgres (dynamic leaderboard) ───────────────────────────────────────
# Added automatically when you connect a Neon database in Vercel:
#   Vercel dashboard → Storage → Create Database → Neon Postgres → Connect to project
# The POSTGRES_URL is the pooled connection string (use for serverless functions).
POSTGRES_URL=postgres://user:password@host/dbname?sslmode=require

# Secret used by the Ubuntu pipeline to authenticate leaderboard publish calls.
# Generate a random string: python3 -c "import secrets; print(secrets.token_hex(32))"
# Must match the value set in Vercel AND in your Ubuntu ~/.bashrc:
#   export LEADERBOARD_PUBLISH_SECRET=your_secret_here
LEADERBOARD_PUBLISH_SECRET=your_random_secret_here
