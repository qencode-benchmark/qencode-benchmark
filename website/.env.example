# ─────────────────────────────────────────────────────────────────────────────
# QEncode website environment variables
# Copy this file to .env.local for local development.
# Add all values to Vercel → Project Settings → Environment Variables for prod.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Lemon Squeezy ─────────────────────────────────────────────────────────────
# Public checkout URLs (already hardcoded as fallbacks in lib/payments.js)
NEXT_PUBLIC_LS_FULL_SUITE_CHECKOUT_URL=https://quantumalgorithmbenchmarking.lemonsqueezy.com/checkout/buy/9bfda82b-15b1-43af-ba2d-70f5a381705d
NEXT_PUBLIC_LS_SINGLE_MOLECULE_CHECKOUT_URL=https://quantumalgorithmbenchmarking.lemonsqueezy.com/checkout/buy/86b8c0a4-ed45-45dd-9fd5-520f097296ec

# Webhook signing secret — from LS Dashboard → Settings → Webhooks → [your webhook] → Signing Secret
# Used to verify that POST requests to /api/webhooks/lemonsqueezy are genuine.
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_signing_secret_here

# ── Resend (transactional email) ──────────────────────────────────────────────
# Get your API key at https://resend.com/api-keys
# Free tier: 3,000 emails/month, 100/day
# The domain qencode-benchmark.org must be verified in Resend before anything
# sends from noreply@qencode-benchmark.org.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Admin email to receive new order notifications.
# Defaults to support@qencode-benchmark.org if not set.
# Informational only — job_poller.py claims paid orders automatically.
ADMIN_EMAIL=support@qencode-benchmark.org

# ── Email/DNS architecture (two systems share one domain) ─────────────────────
# OUTBOUND is Resend, INBOUND is Cloudflare Email Routing. They coexist because
# Resend authenticates on a subdomain, so neither overwrites the other's records:
#
#   MX    qencode-benchmark.org        -> route{1,2,3}.mx.cloudflare.net  (inbound)
#   TXT   qencode-benchmark.org        -> v=spf1 include:_spf.mx.cloudflare.net ~all
#   TXT   resend._domainkey            -> p=...           (Resend DKIM, signs outbound)
#   TXT   send.qencode-benchmark.org   -> v=spf1 include:amazonses.com ~all
#   MX    send.qencode-benchmark.org   -> feedback-smtp.eu-west-1.amazonses.com
#
# Do NOT add include:amazonses.com to the ROOT SPF record. A domain may have only
# one SPF record, and Resend's envelope sender is on send.* — SPF is checked there
# and aligns with the From domain under relaxed alignment. Editing the root SPF
# risks breaking Cloudflare inbound routing for no gain.
#
# noreply@ is SEND-ONLY: it has no Cloudflare Routing rule, so mail addressed to
# it is discarded. Every send in lib/email.js therefore sets replyTo — customer
# replies go to support@, which Cloudflare routes to the team inbox. If you add a
# new sender, set replyTo or the reply is lost silently.
#
# support@qencode-benchmark.org must exist as a Routing rule in
# Cloudflare -> Email -> Email Routing -> Routing rules, or inbound mail bounces.

# ── Neon Postgres (dynamic leaderboard) ───────────────────────────────────────
# Added automatically when you connect a Neon database in Vercel:
#   Vercel dashboard → Storage → Create Database → Neon Postgres → Connect to project
# The POSTGRES_URL is the pooled connection string (use for serverless functions).
POSTGRES_URL=postgres://user:password@host/dbname?sslmode=require

# Secret used by the Ubuntu pipeline to authenticate leaderboard publish calls.
# Generate a random string: python3 -c "import secrets; print(secrets.token_hex(32))"
# Must match the value set in Vercel AND in your Ubuntu ~/.bashrc:
#   export LEADERBOARD_PUBLISH_SECRET=your_secret_here
LEADERBOARD_PUBLISH_SECRET=your_random_secret_here
